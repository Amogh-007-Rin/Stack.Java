<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12" styleClass="root"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Exercise1SolutionController">
    <Label text="Create Account" styleClass="title" />
    <TextField fx:id="fullNameField" promptText="Full Name" />
    <TextField fx:id="emailField" promptText="Email" />
    <PasswordField fx:id="passwordField" promptText="Password" />
    <PasswordField fx:id="confirmField" promptText="Confirm Password" />
    <Label fx:id="messageLabel" styleClass="message" />
    <Button text="Register" onAction="#handleRegister" styleClass="register-button" />
</VBox>
